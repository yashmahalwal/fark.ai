# Backend GitHub Token
BACKEND_GITHUB_TOKEN=your_backend_github_token_here

# Frontend GitHub Token
FRONTEND_GITHUB_TOKEN=your_frontend_github_token_here

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key_here

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# GitHub MCP Server URL
MCP_SERVER_URL=your_mcp_server_url_here

# Optional: Test Configuration (for test-orchestrate.ts)
# BACKEND_OWNER=your-org
# BACKEND_REPO=fark-backend-demo
# BACKEND_PR_NUMBER=1
# FRONTEND_OWNER=your-org
# FRONTEND_REPO=fark-frontend-demo
# FRONTEND_BRANCH=main

# Optional: Multiple Frontend Repos (JSON array format)
# Example: [{"owner":"your-org","repo":"fark-frontend-demo","branch":"main"},{"owner":"your-org","repo":"fark-mobile-demo","branch":"main"}]
# FRONTEND_REPOS=[{"owner":"your-org","repo":"fark-frontend-demo","branch":"main"}]
