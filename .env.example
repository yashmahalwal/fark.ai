# Env file to be used for running the workflow locally
# Used in @src/test-orchestrate.ts

# Backend GitHub token (required for `npm run test:orchestrate`)
# Used only for GitHub MCP against the backend repo (same role as action input `backend_github_token`).
BACKEND_GITHUB_TOKEN=your_backend_github_token_here

# OpenAI API Key (required for all AI agents)
OPENAI_API_KEY=your_openai_api_key_here

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# GitHub MCP Server URL (optional — defaults to GitHub Copilot MCP if unset)
GITHUB_MCP_SERVER_URL=https://api.githubcopilot.com/mcp/

# Backend Configuration (for test-orchestrate.ts)
BACKEND_OWNER=your-org
BACKEND_REPO=fark-backend-demo
BACKEND_PR_NUMBER=1
# Local absolute path to the backend repo (PR branch checkout). In CI, checkout with `path: backend` and set action input `backend_codebase_path` to that folder (e.g. `${{ github.workspace }}/backend`).
BACKEND_CODEBASE_PATH=/path/to/fark-backend-demo

# Frontend Repositories Configuration (JSON array format)
# Each frontend requires: repository (owner, repo, branch) and codebasePath
FRONTENDS=[{"repository":{"owner":"your-org","repo":"fark-frontend-demo","branch":"main"},"codebasePath":"/path/to/fark-frontend-demo"},{"repository":{"owner":"your-org","repo":"fark-mobile-demo","branch":"main"},"codebasePath":"/path/to/fark-mobile-demo"}]

# Agent Token Limits (Optional — defaults match src/constants/agent-token-defaults.ts)

# Frontend Finder
# FRONTEND_FINDER_MAX_STEPS=60                    # Default: 22
# FRONTEND_FINDER_MAX_OUTPUT_TOKENS=16384         # Default: 16384
# FRONTEND_FINDER_MAX_TOTAL_TOKENS=500000         # Default: 150000
# FRONTEND_FINDER_CONCURRENCY_LIMIT=8             # Default: 5 (orchestrate / env)

# BE Analyzer
# BE_ANALYZER_MAX_STEPS=30                        # Default: 15
# BE_ANALYZER_MAX_OUTPUT_TOKENS=16384             # Default: 16384
# BE_ANALYZER_MAX_TOTAL_TOKENS=200000             # Default: 100000

# Comment Generator
# COMMENT_GENERATOR_MAX_STEPS=20                  # Default: 12
# COMMENT_GENERATOR_MAX_OUTPUT_TOKENS=8192        # Default: 8192
# COMMENT_GENERATOR_MAX_TOTAL_TOKENS=100000       # Default: 48000

# PR Comment Poster — raise for many inline comments / long bodies
# PR_COMMENT_POSTER_MAX_STEPS=80                  # Default: 45
# PR_COMMENT_POSTER_MAX_OUTPUT_TOKENS=8192        # Default: 8192
# PR_COMMENT_POSTER_MAX_TOTAL_TOKENS=300000       # Default: 150000
