# Backend GitHub Token (required for GitHub MCP operations)
BACKEND_GITHUB_TOKEN=your_backend_github_token_here

# OpenAI API Key (required for all AI agents)
OPENAI_API_KEY=your_openai_api_key_here

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# GitHub MCP Server URL
MCP_SERVER_URL=https://api.githubcopilot.com/mcp/

# Backend Configuration (for test-orchestrate.ts)
BACKEND_OWNER=your-org
BACKEND_REPO=fark-backend-demo
BACKEND_PR_NUMBER=1
BACKEND_CODEBASE_PATH=/path/to/fark-backend-demo

# Frontend Repositories Configuration (JSON array format)
# Each frontend requires: repository (owner, repo, branch) and codebasePath
FRONTENDS=[{"repository":{"owner":"your-org","repo":"fark-frontend-demo","branch":"main"},"codebasePath":"/path/to/fark-frontend-demo"},{"repository":{"owner":"your-org","repo":"fark-mobile-demo","branch":"main"},"codebasePath":"/path/to/fark-mobile-demo"}]

# Agent Token Limits (Optional - defaults shown in comments)
# Adjust these for larger PRs or more complex codebases

# Frontend Finder - most token-intensive, increase significantly for large PRs
FRONTEND_FINDER_MAX_STEPS=60                    # Default: 40
FRONTEND_FINDER_MAX_OUTPUT_TOKENS=50000         # Default: 50000
FRONTEND_FINDER_MAX_TOTAL_TOKENS=1000000        # Default: 500000

# BE Analyzer - increase if PR has many changes
BE_ANALYZER_MAX_STEPS=30                        # Default: 20
BE_ANALYZER_MAX_OUTPUT_TOKENS=50000             # Default: 50000
BE_ANALYZER_MAX_TOTAL_TOKENS=400000             # Default: 200000

# Comment Generator - increase if expecting many comments
COMMENT_GENERATOR_MAX_STEPS=25                  # Default: 15
COMMENT_GENERATOR_MAX_OUTPUT_TOKENS=30000       # Default: 30000
COMMENT_GENERATOR_MAX_TOTAL_TOKENS=200000       # Default: 100000

# PR Comment Poster - increase steps if many comments
PR_COMMENT_POSTER_MAX_STEPS=100                 # Default: 60
PR_COMMENT_POSTER_MAX_OUTPUT_TOKENS=5000        # Default: 5000
PR_COMMENT_POSTER_MAX_TOTAL_TOKENS=500000       # Default: 300000
