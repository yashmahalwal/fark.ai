{
  "name": "fark-ai",
  "version": "1.0.0",
  "description": "Fark AI GitHub Action",
  "main": "dist/index.js",
  "scripts": {
    "build": "rm -rf dist && esbuild src/index.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/index.js --sourcemap --external:@mongodb-js/zstd",
    "start": "node dist/index.js",
    "build:dev": "esbuild src/test-orchestrate.ts --bundle --platform=node --target=node20 --format=cjs --outfile=dist/test-orchestrate.js --sourcemap --external:@mongodb-js/zstd",
    "package": "npm run build && npm pack",
    "test": "jest",
    "dev": "npm run build:dev && node dist/test-orchestrate.js",
    "debug": "npm run build:dev && node --inspect-brk dist/test-orchestrate.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .prettierignore"
  },
  "keywords": [
    "actions",
    "github",
    "fark-ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^6.0.1",
    "@ai-sdk/mcp": "^1.0.1",
    "@ai-sdk/openai": "^3.0.1",
    "ai": "^6.0.0",
    "just-bash": "^2.5.5",
    "p-limit": "^7.2.0",
    "pino": "^10.1.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/pino": "^7.0.4",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-jest": "^30.2.0",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
