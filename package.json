{
  "name": "fark-ai",
  "version": "1.0.0",
  "description": "Fark AI GitHub Action",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "npm run build && npm pack",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "actions",
    "github",
    "fark-ai"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.1",
    "@actions/github": "^6.0.1",
    "@ai-sdk/mcp": "^1.0.1",
    "@ai-sdk/openai": "^3.0.1",
    "ai": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.50.1",
    "@typescript-eslint/parser": "^8.50.1",
    "babel-jest": "^30.2.0",
    "eslint": "^9.39.2",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "typescript": "^5.9.3"
  }
}
